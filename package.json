{
  "name": "studio-white",
  "private": true,
  "version": "1.0.0",
  "description": "Studio White: landing (React) + panel admin (Node/Express + MySQL)",
  "scripts": {
    "install:all": "npm --prefix backend install && npm --prefix frontend install",
    "setup": "npm --prefix backend run setup",
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "start:backend": "npm --prefix backend start"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
