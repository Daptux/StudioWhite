# SPA fallback para Hostinger/Apache: cualquier ruta inexistente
# (ej: /login, /admin) sirve index.html para que React Router funcione.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
